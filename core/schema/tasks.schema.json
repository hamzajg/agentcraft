{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tasks",
  "description": "Planner agent output — file-level tasks for one iteration",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "iteration_id", "agent", "file", "description", "context_files", "acceptance_criteria"],
    "properties": {
      "id": {
        "type": "string",
        "description": "Unique task ID, e.g. 'iter1_task1'"
      },
      "iteration_id": {
        "type": "integer",
        "description": "Parent iteration ID"
      },
      "agent": {
        "type": "string",
        "enum": ["backend_dev", "config_agent", "docs_agent"],
        "description": "Which agent implements this task"
      },
      "file": {
        "type": "string",
        "description": "Relative path to the file to create or edit"
      },
      "description": {
        "type": "string",
        "description": "Precise implementation instructions for the agent"
      },
      "context_files": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Relative paths of existing files the agent should read for context"
      },
      "acceptance_criteria": {
        "type": "array",
        "items": { "type": "string" },
        "minItems": 2,
        "description": "Concrete criteria the reviewer uses to approve or reject"
      }
    }
  }
}
