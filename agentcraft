# ── Parser ────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        prog="agentcraft",
        description="Autonomous AI agent team — build software from docs",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    subs = parser.add_subparsers(dest="command", metavar="<command>")

    # ── init ──────────────────────────────────────────────────────────────────
    p = subs.add_parser("init", help="Set up a new project (interactive)")
    p.add_argument("--force", action="store_true", help="Re-initialise even if workspace.yaml exists")
    p.add_argument("--deps",  action="store_true", help="Also install Python dependencies")
    p.set_defaults(func=cmd_init)

    # ── diagnose ──────────────────────────────────────────────────────────────
    p = subs.add_parser("diagnose", help="Detect hardware, select optimal models")
    p.add_argument("--pull",    action="store_true", help="Pull selected models from Ollama")
    p.add_argument("--dry-run", action="store_true", dest="dry_run", help="Show only, no writes")
    p.add_argument("--tier",    choices=["minimal","standard","performance","high-end"],
                   help="Override detected tier")
    p.set_defaults(func=cmd_diagnose)

    # ── build ─────────────────────────────────────────────────────────────────
    global build_parser
    p = build_parser = subs.add_parser("build", help="Validate workspace, pull models — no execution")
    p.add_argument("--model",       default=None)
    p.add_argument("--framework",   default=None)
    p.add_argument("--rag",         action="store_true", default=None)
    p.add_argument("--no-rag",      action="store_true")
    p.add_argument("--no-validate", action="store_true")
    p.set_defaults(func=cmd_build)

    # ── bootstrap ─────────────────────────────────────────────────────────────
    global bootstrap_parser
    p = bootstrap_parser = subs.add_parser("bootstrap", help="Run the agent workflow (execution phase)")
    p.add_argument("--model",           default=None)
    p.add_argument("--framework",       default=None)
    p.add_argument("--phase",           type=int, default=None)
    p.add_argument("--from",            type=int, default=1, dest="from_iter", metavar="N")
    p.add_argument("--skip-spec",       action="store_true")
    p.add_argument("--rag",             action="store_true", default=None)
    p.add_argument("--no-rag",          action="store_true")
    p.add_argument("--max-rework-task", type=int, default=None)
    p.add_argument("--max-rework-iter", type=int, default=None)
    p.add_argument("--parallel",        action="store_true", help="Run agents in parallel (experimental)")
    p.set_defaults(func=cmd_bootstrap)

    # ── resume ────────────────────────────────────────────────────────────────
    # Alias for bootstrap — bootstrap auto-detects checkpoint by default
    p = subs.add_parser("resume", help="Resume workflow (alias for bootstrap --from)")
    p.add_argument("--from", type=int, default=None, dest="from_iter", metavar="N",
                   help="Resume from specific iteration (optional — auto-detects if omitted)")
    p.add_argument("--model", default=None)
    p.add_argument("--framework", default=None)
    p.add_argument("--rag", action="store_true", default=None)
    p.add_argument("--no-rag", action="store_true")
    p.add_argument("--phase", type=int, default=None)
    p.add_argument("--skip-spec", action="store_true", default=True)
    p.add_argument("--max-rework-task", type=int, default=None)
    p.add_argument("--max-rework-iter", type=int, default=None)
    p.add_argument("--parallel", action="store_true")
    p.set_defaults(func=cmd_bootstrap)

    # ── comms ─────────────────────────────────────────────────────────────────
    p = subs.add_parser("comms", help="Start the human↔agent comms UI")
    p.add_argument("--port",     type=int, default=7000)
    p.add_argument("--dev",      action="store_true", help="Hot-reload mode")
    p.add_argument("--build-ui", action="store_true", help="Rebuild React frontend first")
    p.set_defaults(func=cmd_comms)
    
    # ── comms-stop ────────────────────────────────────────────────────────────
    p = subs.add_parser("comms-stop", help="Stop any running comms server")
    p.add_argument("--port", type=int, default=7000)
    p.set_defaults(func=cmd_comms_stop)

    # ── chat ──────────────────────────────────────────────────────────────────
    global chat_parser
    p = chat_parser = subs.add_parser("chat", help="Chat with a specific agent via CLI")
    p.add_argument("agent", help="Agent name (e.g. architect, backend_dev)")
    p.add_argument("--model", default=None)
    p.add_argument("--framework", default=None)
    p.add_argument("--rag", action="store_true", default=None)
    p.add_argument("--no-rag", action="store_true")
    p.set_defaults(func=cmd_chat)

    # ── monitor ───────────────────────────────────────────────────────────────
    p = subs.add_parser("monitor", help="Live system metrics monitor")
    p.add_argument("--interval", type=float, default=2.0, help="Refresh interval (s)")
    p.add_argument("--once",     action="store_true", help="Single snapshot and exit")
    p.set_defaults(func=cmd_monitor)

    # ── rag ───────────────────────────────────────────────────────────────────
    p = subs.add_parser("rag", help="RAG repository inspector")
    rag_subs = p.add_subparsers(dest="subcommand")
    rag_subs.add_parser("stats",       help="Index health summary")
    rag_subs.add_parser("collections", help="Breakdown by collection")
    rag_subs.add_parser("languages",   help="Breakdown by language")

    pf = rag_subs.add_parser("files",   help="Per-file breakdown")
    pf.add_argument("--top", type=int, default=50)

    pq = rag_subs.add_parser("queries", help="Query activity log")
    pq.add_argument("--limit", type=int, default=20)

    ps = rag_subs.add_parser("search",  help="Test semantic search")
    ps.add_argument("query")
    ps.add_argument("--top-k", type=int, default=5)

    rag_subs.add_parser("reset",    help="Clear query log")
    pri = rag_subs.add_parser("reindex", help="Re-index docs and repo")
    pri.add_argument("--force", action="store_true")
    p.set_defaults(func=cmd_rag)

    # ── validate ──────────────────────────────────────────────────────────────
    p = subs.add_parser("validate", help="Check ownership boundary")
    p.add_argument("--staged", action="store_true", help="Check staged files only (pre-commit)")
    p.set_defaults(func=cmd_validate)

    # ── new-agent ─────────────────────────────────────────────────────────────
    p = subs.add_parser("new-agent", help="Scaffold a new agent folder")
    p.add_argument("name", help="Agent name (snake_case, e.g. security_auditor)")
    p.set_defaults(func=cmd_new_agent)

    # ── frameworks / skills ───────────────────────────────────────────────────
    p = subs.add_parser("frameworks", help="List available frameworks")
    p.set_defaults(func=cmd_frameworks)

    p = subs.add_parser("skills", help="List available skills")
    p.add_argument("--framework", default=None)
    p.set_defaults(func=cmd_skills)

    # ── build-state / reset-events ────────────────────────────────────────
    p = subs.add_parser("build-state", help="Show current build state from event store")
    p.set_defaults(func=cmd_build_state)

    p = subs.add_parser("reset-events", help="Clear the event store (fresh start)")
    p.add_argument("--force", action="store_true", help="Skip confirmation")
    p.set_defaults(func=cmd_reset_events)

    # ── parse and dispatch ────────────────────────────────────────────────────
    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        return

    if not hasattr(args, "func"):
        parser.error(f"Unknown command: {args.command}")

    args.func(args)


if __name__ == "__main__":
    main()
