# ── build ─────────────────────────────────────────────────────────────────────

def cmd_build(args):
    """Prepare workspace, validate config, pull models — no agent execution."""
    import shutil

    ws_root = _find_workspace_root()
    if not ws_root:
        print("  ✗ No workspace found — run: agentcraft init")
        sys.exit(1)

    ws = _load_ws()
    _require_yaml(build_parser)

    team     = ws.get("agent_team", {})
    paths    = ws.get("paths", {})
    rag_cfg  = ws.get("rag", {})
    project  = ws.get("project", {})

    model     = args.model     or team.get("model", "qwen2.5-coder:7b")
    framework = args.framework or team.get("framework")
    docs_dir  = ws_root / paths.get("docs", "docs")
    workspace = ws_root / paths.get("output", ".")

    if args.rag:   rag_cfg["enabled"] = True
    if args.no_rag: rag_cfg["enabled"] = False

    print(f"\n  {'='*60}")
    print(f"  Build — {project.get('name', '?')}")
    print(f"  Workspace:  {ws_root}")
    print(f"  {'='*60}")

    # ── 1. Validate workspace ────────────────────────────────────────────
    if not docs_dir.exists():
        print(f"  ✗ Docs dir not found: {docs_dir}")
        print(f"  Run: agentcraft init   to set up workspace")
        sys.exit(1)
    print(f"  ✓ Workspace:  {workspace}")
    print(f"  ✓ Docs:       {docs_dir}  ({len(list(docs_dir.glob('*.md')))} files)")
    print(f"  ✓ Model:      {model}")
    print(f"  ✓ Framework:  {framework or 'none'}")
    print(f"  ✓ RAG:        {'enabled' if rag_cfg.get('enabled') else 'disabled'}")

    # ── 2. Validate framework ────────────────────────────────────────────
    if framework:
        from core.framework_loader import FrameworkLoader
        if framework not in FrameworkLoader.list_frameworks():
            print(f"  ✗ Unknown framework '{framework}'")
            print(f"    Available: {FrameworkLoader.list_frameworks()}")
            sys.exit(1)
        print(f"  ✓ Framework '{framework}' loaded")

    # ── 3. Validate ownership boundaries ─────────────────────────────────
    if not args.no_validate:
        from core.validate.validate import main as validate_main
        sys.argv = ["validate", "--quiet"]
        try:
            validate_main()
            print(f"  ✓ Ownership boundaries valid")
        except SystemExit as e:
            if e.code != 0:
                print(f"  ✗ Ownership boundary violations found")
                print(f"    Run: agentcraft validate   for details")
                sys.exit(1)
    else:
        print(f"  — Validation skipped (--no-validate)")

    # ── 4. Pull models ──────────────────────────────────────────────────
    if not shutil.which("ollama"):
        print(f"  ✗ Ollama not found — install it first")
        sys.exit(1)

    import subprocess
    models_to_pull = [model]
    if rag_cfg.get("enabled"):
        embed = rag_cfg.get("embed_model", "nomic-embed-text")
        if embed not in models_to_pull:
            models_to_pull.append(embed)

    for m in models_to_pull:
        print(f"  Pulling model: {m} ... ", end="", flush=True)
        result = subprocess.run(
            ["ollama", "pull", m],
            capture_output=True, text=True, timeout=600
        )
        print("ok" if result.returncode == 0 else "FAILED")
        if result.returncode != 0:
            print(f"    {result.stderr[:200]}")
            sys.exit(1)

    # ── 5. Ready ────────────────────────────────────────────────────────
    (ws_root / ".ai").mkdir(exist_ok=True)

    print(f"\n  {'='*60}")
    print(f"  Build complete — workspace ready")
    print(f"  {'='*60}")
    print(f"  Run the agents:")
    print(f"    agentcraft bootstrap          # run full workflow")
    print(f"    agentcraft bootstrap --from 5 # resume from iteration 5")
    print(f"  Open collaboration UI:")
    print(f"    agentcraft comms")
    print()


# ── helpers: checkpoint detection ───────────────────────────────────────────

def _detect_checkpoint() -> int:
    """Auto-detect resume point from the persistent event store."""
    ws_root = _find_workspace_root()
    if not ws_root:
        return 1
    events_path = ws_root / ".ai" / "events.jsonl"

    # Try event store first
    if events_path.exists():
        try:
            import json
            state = {
                "completed_iterations": [],
                "build_status": "idle",
                "resume_from_iteration": 1,
            }

            with open(events_path) as f:
                for line in f:
                    line = line.strip()
                    if not line:
                        continue
                    try:
                        ev = json.loads(line)
                    except json.JSONDecodeError:
                        continue

                    etype = ev.get("type", "")
                    data = ev.get("data", {})

                    if etype == "build_started":
                        # New build boundary — reset tracking
                        state["completed_iterations"] = []
                        state["build_status"] = "running"

                    elif etype == "build_done":
                        state["build_status"] = "done"

                    elif etype == "stopped":
                        state["build_status"] = "stopped"

                    elif etype == "error":
                        state["build_status"] = "error"

                    elif etype == "iter_done":
                        iter_id = data.get("id")
                        approved = data.get("approved", False)
                        if iter_id is not None:
                            if approved:
                                if iter_id not in state["completed_iterations"]:
                                    state["completed_iterations"].append(iter_id)

            # Determine resume point from last build's state
            if state["build_status"] in ("done",):
                return 1  # Completed — fresh start
            if state["completed_iterations"]:
                return max(state["completed_iterations"]) + 1
            return 1

        except Exception as e:
            print(f"  Warning: Event store read failed: {e}")

    # Fallback: read run_log.json
    log_path = ws_root / ".ai" / "run_log.json"
    if not log_path.exists():
        return 1
    try:
        import json
        data = json.loads(log_path.read_text())
        iterations = data.get("iterations", [])
        if not iterations:
            return 1
        last_approved = 0
        for it in iterations:
            if it.get("approved"):
                last_approved = max(last_approved, it.get("iteration_id", 0))
        return last_approved + 1
    except Exception:
        return 1


# ── helpers: shared bootstrap setup ────────────────────────────────────────

def _run_workflow(args, start_from_iteration: int):
    """Shared workflow execution — uses workspace root detection."""
    import shutil

    ws_root = _find_workspace_root()
    if not ws_root:
        print("ERROR: No workspace found. Run: agentcraft init")
        sys.exit(1)

    ws = _load_ws()
    _require_yaml(bootstrap_parser)

    team     = ws.get("agent_team", {})
    paths    = ws.get("paths", {})
    rag_cfg  = ws.get("rag", {})

    model     = args.model     or team.get("model", "qwen2.5-coder:7b")
    framework = args.framework or team.get("framework")
    docs_dir  = ws_root / paths.get("docs", "docs")
    workspace = ws_root / paths.get("output", ".")

    if args.rag:   rag_cfg["enabled"] = True
    if args.no_rag: rag_cfg["enabled"] = False

    if not shutil.which("aider"):
        print("ERROR: aider not found. Run: agentcraft init --deps")
        sys.exit(1)
    if not docs_dir.exists():
        print(f"ERROR: docs dir not found: {docs_dir}")
        sys.exit(1)

    # ── Start comms server ───────────────────────────────────────────────
    comms_process = None
    comms_port = 7000

    import socket
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    comms_already_running = sock.connect_ex(('localhost', comms_port)) == 0
    sock.close()

    if comms_already_running:
        print(f"  Comms server already running on port {comms_port}")
    else:
        print("  Starting comms server...")
        import subprocess, time, signal
        try:
            comms_process = subprocess.Popen([
                sys.executable, "-m", "uvicorn", "comms.main:app",
                f"--port={comms_port}", "--log-level=warning"
            ], cwd=str(ws_root))
            time.sleep(3)
            print(f"  Comms server ready at http://localhost:{comms_port}")

            cleanup_done = False
            def cleanup_comms(signum, frame):
                nonlocal cleanup_done
                if cleanup_done:
                    return
                cleanup_done = True
                print("\n  Stopping comms server...")
                if comms_process and comms_process.poll() is None:
                    comms_process.terminate()
                    try:
                        comms_process.wait(timeout=5)
                    except subprocess.TimeoutExpired:
                        comms_process.kill()
                        comms_process.wait()
                    print("  Comms server stopped.")
                sys.exit(0)

            signal.signal(signal.SIGINT, cleanup_comms)
            signal.signal(signal.SIGTERM, cleanup_comms)
        except Exception as e:
            print(f"  Warning: Could not start comms server: {e}")

    # ── Logging ──────────────────────────────────────────────────────────
    import logging
    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s  %(levelname)-8s  %(message)s",
        datefmt="%H:%M:%S",
        handlers=[
            logging.StreamHandler(sys.stdout),
            logging.FileHandler(str(ws_root / ".ai" / "bootstrap.log"), mode="a") if (ws_root / ".ai").exists()
            else logging.NullHandler(),
        ],
    )
    logging.getLogger("httpx").setLevel(logging.WARNING)
    logging.getLogger("httpcore").setLevel(logging.WARNING)
    os.environ["COMMS_SERVER_URL"] = f"http://localhost:{comms_port}"
    (ws_root / ".ai").mkdir(exist_ok=True)

    # ── Orchestrator ─────────────────────────────────────────────────────
    from core.orchestrator import Orchestrator

    legacy_dirs = []
    if ws.get("project", {}).get("type") == "legacy":
        for d in rag_cfg.get("legacy_source_dirs", []):
            p = ws_root / d
            if p.exists():
                legacy_dirs.append(p)

    orch = Orchestrator(
        model=model,
        docs_dir=docs_dir,
        workspace=workspace,
        framework_id=framework,
        max_rework_per_task=args.max_rework_task or team.get("max_rework_task", 3),
        max_rework_per_iter=args.max_rework_iter or team.get("max_rework_iter", 2),
        start_from_iteration=start_from_iteration,
        skip_spec=getattr(args, "skip_spec", False),
        rag_config=rag_cfg,
        legacy_dirs=legacy_dirs,
        parallel=getattr(args, "parallel", False),
    )

    # Phase filter (optional)
    if getattr(args, "phase", None):
        orig = orch.architect.plan
        def _filtered(docs_dir):
            return [i for i in orig(docs_dir) if i.get("phase", 1) == args.phase]
        orch.architect.plan = _filtered

    # ── Run ──────────────────────────────────────────────────────────────
    run_log = orch.run()
    approved = sum(1 for i in run_log.iterations if i.approved)

    if not any(docs_dir.glob("*.md")):
        print(f"\n  Bootstrap complete: phase 0 collaboration finished")
        print("  Review docs/ and run again to proceed.")
    else:
        print(f"\n  {'='*60}")
        print(f"  Done: {approved}/{len(run_log.iterations)} iterations approved")
        print(f"  Log: .ai/run_log.json")
        print(f"  Commit output:")
        print(f"    git add . && git commit -m 'feat: agent iteration {start_from_iteration}+'")

    # ── Comms cleanup ────────────────────────────────────────────────────
    shutdown_done = False
    def _shutdown():
        nonlocal shutdown_done
        if shutdown_done:
            return
        shutdown_done = True
        print("\n  Stopping comms server...")
        if comms_process and comms_process.poll() is None:
            comms_process.terminate()
            try:
                comms_process.wait(timeout=5)
            except subprocess.TimeoutExpired:
                comms_process.kill()
                comms_process.wait()
            print("  Comms server stopped.")

    if comms_process:
        print(f"\n  Comms server still running at http://localhost:{comms_port}")
        print("  Press Ctrl+C to stop.")
        import signal
        signal.signal(signal.SIGINT, lambda s, f: _shutdown())
        signal.signal(signal.SIGTERM, lambda s, f: _shutdown())
        try:
            comms_process.wait()
        except KeyboardInterrupt:
            _shutdown()
    elif comms_already_running:
        print(f"\n  Comms server still running at http://localhost:{comms_port}")
        print("  (Started before this session — not managed here)")


# ── bootstrap ────────────────────────────────────────────────────────────────

def cmd_bootstrap(args):
    """Run the agent workflow — auto-resumes from last checkpoint."""
    ws = _load_ws()
    _require_yaml(bootstrap_parser)

    # Auto-detect checkpoint unless user overrides
    checkpoint = getattr(args, "from_iter", None)
    if checkpoint is not None and checkpoint > 1:
        start_from = checkpoint
        print(f"  Resuming from iteration {start_from} (--from)")
    else:
        start_from = _detect_checkpoint()
        if start_from > 1:
            print(f"  Auto-resume: last completed checkpoint was iteration {start_from - 1}")
        else:
            print(f"  Fresh start — no previous checkpoint found")

    _run_workflow(args, start_from)


# ── comms ─────────────────────────────────────────────────────────────────────

def cmd_comms(args):
    """Start the human↔agent communication UI."""
    import subprocess, shutil
    if not shutil.which("uvicorn"):
        print("Installing uvicorn...")
        subprocess.run([sys.executable, "-m", "pip", "install", "uvicorn", "fastapi"], check=True)

    comms_dir = AGENTCRAFT_HOME / "comms"
    port = args.port or 7000
    
    # Check if already running
    import socket
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    if sock.connect_ex(('localhost', port)) == 0:
        print(f"  Comms server already running on port {port}")
        print(f"  Open: http://localhost:{port}")
        sock.close()
        return
    sock.close()

    if args.build_ui:
        print("Building React UI...")
        subprocess.run(["bash", str(comms_dir / "build.sh")], check=True)

    print(f"  Starting comms server on http://localhost:{port}")
    os.environ["COMMS_SERVER_URL"] = f"http://localhost:{port}"
    subprocess.run(
        ["uvicorn", "comms.main:app", f"--port={port}",
         "--reload" if args.dev else "--workers=1"],
        cwd=str(AGENTCRAFT_HOME),
    )


def cmd_comms_stop(args):
    """Stop any running comms server."""
    import socket
    import subprocess
    
    port = args.port or 7000
    
    # Check if something is running on the port
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    if sock.connect_ex(('localhost', port)) != 0:
        print(f"  No comms server running on port {port}")
        sock.close()
        return
    sock.close()
    
    print(f"  Stopping comms server on port {port}...")
    
    # Find and kill the process
    try:
        # Try to find uvicorn process on this port
        result = subprocess.run(
            ["lsof", "-ti", f":{port}"],
            capture_output=True,
            text=True,
            timeout=5
        )
        
        if result.returncode == 0 and result.stdout.strip():
            pids = result.stdout.strip().split('\n')
            for pid in pids:
                pid = pid.strip()
                if pid:
                    try:
                        subprocess.run(["kill", pid], timeout=3)
                        print(f"  Stopped process {pid}")
                    except Exception as e:
                        print(f"  Failed to stop {pid}: {e}")
            print(f"  Comms server on port {port} stopped.")
        else:
            # Fallback: try to kill by process name
            result = subprocess.run(
                ["pkill", "-f", f"uvicorn.*comms.main.*--port={port}"],
                timeout=5
            )
            if result.returncode == 0:
                print(f"  Comms server on port {port} stopped.")
            else:
                print(f"  Could not find comms server process.")
                print(f"  You may need to manually kill the process on port {port}")
    except FileNotFoundError:
        print("  Error: lsof or pkill not found.")
        print(f"  Please manually kill the process using port {port}")
        print(f"  Run: lsof -ti :{port} | xargs kill")
