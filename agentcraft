# ── Helpers ───────────────────────────────────────────────────────────────────

def _to_class_name(name: str) -> str:
    return "".join(w.title() for w in name.split("_")) + "Agent"


# ── Parser ────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        prog="agentcraft",
        description="Autonomous AI agent team — build software from docs",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    subs = parser.add_subparsers(dest="command", metavar="<command>")

    # ── init ──────────────────────────────────────────────────────────────────
    p = subs.add_parser("init", help="Set up a new project (interactive)")
    p.add_argument("--force", action="store_true", help="Re-initialise even if workspace.yaml exists")
    p.add_argument("--deps",  action="store_true", help="Also install Python dependencies")
    p.set_defaults(func=cmd_init)

    # ── diagnose ──────────────────────────────────────────────────────────────
    p = subs.add_parser("diagnose", help="Detect hardware, select optimal models")
    p.add_argument("--pull",    action="store_true", help="Pull selected models from Ollama")
    p.add_argument("--dry-run", action="store_true", dest="dry_run", help="Show only, no writes")
    p.add_argument("--tier",    choices=["minimal","standard","performance","high-end"],
                   help="Override detected tier")
    p.set_defaults(func=cmd_diagnose)

    # ── build ─────────────────────────────────────────────────────────────────
    global build_parser
    p = build_parser = subs.add_parser("build", help="Run the full agent team build")
    p.add_argument("--model",           default=None)
    p.add_argument("--framework",       default=None)
    p.add_argument("--phase",           type=int, default=None)
    p.add_argument("--from",            type=int, default=1, dest="from_iter", metavar="N")
    p.add_argument("--skip-spec",       action="store_true")
    p.add_argument("--rag",             action="store_true", default=None)
    p.add_argument("--no-rag",          action="store_true")
    p.add_argument("--max-rework-task", type=int, default=None)
    p.add_argument("--max-rework-iter", type=int, default=None)
    p.add_argument("--no-validate",     action="store_true")
