def cmd_rag(args):
    """RAG repository inspector."""
    # Delegate to rag_cli with the sub-subcommand
    from rag.rag_cli import main as rag_main
    # Reconstruct sys.argv so rag_cli's argparser sees the right subcommand
    sub_args = [args.subcommand]
    if hasattr(args, "query") and args.query:
        sub_args.append(args.query)
    if hasattr(args, "top") and args.top:
        sub_args += ["--top", str(args.top)]
    if hasattr(args, "limit") and args.limit:
        sub_args += ["--limit", str(args.limit)]
    if hasattr(args, "force") and args.force:
        sub_args.append("--force")
    sys.argv = ["agentcraft rag"] + sub_args
    rag_main()


