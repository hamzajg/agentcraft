# ── build-state / reset-events ─────────────────────────────────────────────

def cmd_build_state(args):
    """Show current build state from event store."""
    ws_root = _find_workspace_root()
    if not ws_root:
        print("  No workspace found — no build history")
        return
    events_path = ws_root / ".ai" / "events.jsonl"
    if not events_path.exists():
        print("  No event store found — no build history")
        return

    checkpoint = _detect_checkpoint()
    state = {}
    try:
        import json
        completed = []
        build_status = "idle"
        with open(events_path) as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    ev = json.loads(line)
                except json.JSONDecodeError:
                    continue
                etype = ev.get("type", "")
                data = ev.get("data", {})
                if etype == "build_started":
                    completed = []
                    build_status = "running"
                elif etype == "build_done":
                    build_status = "done"
                elif etype == "iter_done" and data.get("approved"):
                    iid = data.get("id")
                    if iid and iid not in completed:
                        completed.append(iid)
        state = {"build_status": build_status, "completed_iterations": completed}
    except Exception:
        pass

    print(f"\n  {'='*40}")
    print(f"  Build State")
    print(f"  {'='*40}")
    print(f"  Status:        {state.get('build_status', 'unknown')}")
    print(f"  Iterations:    {len(state.get('completed_iterations', []))} approved")
    print(f"  Resume from:   iteration {checkpoint}")
    print(f"  Events file:   {events_path}")
    if events_path.exists():
        size = events_path.stat().st_size
        print(f"  Events size:   {size:,} bytes")
    print()


def cmd_reset_events(args):
    """Clear the event store — starts fresh."""
    ws_root = _find_workspace_root()
    if not ws_root:
        print("  No workspace found")
        return
    events_path = ws_root / ".ai" / "events.jsonl"
    if not events_path.exists():
        print("  No event store to clear")
        return

    if not args.force:
        ans = input(f"  Clear {events_path}? [y/N] ").strip().lower()
        if ans != "y":
            print("  Aborted.")
            return

    events_path.unlink()
    print(f"  Cleared: {events_path}")
    print("  Next 'agentcraft bootstrap' will start fresh.")


