#!/usr/bin/env python3
"""
agentcraft — the autonomous AI agent team CLI.

Usage:
  agentcraft init                  Set up a new project (interactive)
  agentcraft diagnose              Detect hardware, select optimal models
  agentcraft build                 Validate workspace, pull models — no execution
  agentcraft bootstrap             Run the agent workflow (auto-resumes from checkpoint)
  agentcraft resume --from N       Resume from a specific iteration
  agentcraft build-state           Show current build state from event store
  agentcraft reset-events          Clear event store for fresh start
  agentcraft comms                 Start the human↔agent comms UI
  agentcraft chat <agent>          Chat with a specific agent via CLI
  agentcraft monitor               Live system metrics monitor
  agentcraft rag <subcommand>      RAG repository inspector
  agentcraft validate              Check ownership boundary
  agentcraft new-agent <name>      Scaffold a new agent folder
  agentcraft frameworks            List available frameworks
  agentcraft skills                List available skills

Run `agentcraft <command> --help` for options.
"""

import argparse
import sys
import os
import re
from pathlib import Path

# AgentCraft installation directory (where this script lives)
AGENTCRAFT_HOME = Path(__file__).parent.resolve()
if str(AGENTCRAFT_HOME) not in sys.path:
    sys.path.insert(0, str(AGENTCRAFT_HOME))

# Try to import yaml, install if needed
try:
    import yaml
except ImportError:
    import subprocess
    subprocess.run([sys.executable, "-m", "pip", "install", "pyyaml", "-q"], check=True)
    import yaml


# ── Helpers ────────────────────────────────────────────────────────────────────

def _to_kebab_case(name: str) -> str:
    """Convert a string to kebab-case."""
    # Lowercase, replace spaces/special chars with hyphens
    s = name.lower().strip()
    s = re.sub(r"[^a-z0-9]+", "-", s)
    s = s.strip("-")
    return s or "my-project"


def _find_workspace_root(start: Path = None) -> Path:
    """Walk up from start (or CWD) looking for workspace.yaml.
    Returns the directory containing workspace.yaml, or None."""
    cur = start or Path.cwd()
    for d in [cur] + list(cur.parents):
        if (d / "workspace.yaml").exists():
            return d
    return None


def _workspace_yaml() -> Path:
    """Return path to workspace.yaml — checks CWD first, then AGENTCRAFT_HOME."""
    # 1. Check if we're inside a workspace-repo (has workspace.yaml)
    ws = _find_workspace_root()
    if ws:
        return ws / "workspace.yaml"
    # 2. Fallback: legacy behaviour — agentcraft home dir
    return AGENTCRAFT_HOME / "workspace.yaml"


def _load_ws() -> dict:
    p = _workspace_yaml()
    if not p.exists():
        return {}
    try:
        return yaml.safe_load(p.read_text()) or {}
    except Exception:
        return {}


def _require_yaml(parser):
    ws_root = _find_workspace_root()
    if not ws_root or not (ws_root / "workspace.yaml").exists():
        parser.error(
            "workspace.yaml not found.\n"
            "  Run: agentcraft init   to create a workspace."
        )


# ── init ──────────────────────────────────────────────────────────────────────

def cmd_init(args):
    """Interactive project initialisation — creates an isolated workspace-repo."""
    print("\n  AgentCraft — Workspace Initialisation\n")

    ws = _load_ws()
    existing = bool(ws)

    if existing:
        ws_path = _workspace_yaml()
        ws_root = ws_path.parent
        print(f"  Found existing workspace: {ws_root}")
        print(f"  Project: {ws.get('project', {}).get('name', '?')}")
        if not args.force:
            ans = input("  Re-initialise? [y/N] ").strip().lower()
            if ans != "y":
                print("  Aborted.")
                return

    # Collect project info
    name        = input("  Project name:                    ").strip() or "my-project"
    repo_name   = input(f"  Workspace repo name              (default: {_to_kebab_case(name)}): ").strip() or _to_kebab_case(name)
    ptype       = input("  Type [greenfield/legacy]         (default: greenfield): ").strip() or "greenfield"
    architecture = input("  Architecture                     (default: monolith): ").strip() or "monolith"
    docs        = input("  Docs directory                   (default: ./docs): ").strip() or "./docs"
    model       = input("  Ollama model                     (default: auto-detect): ").strip()
    framework   = input("  Framework [bmad-method/openspec/none] (default: none): ").strip() or ""

    # Determine workspace directory
    ws_dir = AGENTCRAFT_HOME / repo_name
    if ws_dir.exists() and (ws_dir / "workspace.yaml").exists():
        if not args.force:
            print(f"\n  ⚠ Workspace already exists: {ws_dir}")
            ans = input("  Overwrite? [y/N] ").strip().lower()
            if ans != "y":
                print("  Aborted.")
                return

    # Create workspace directory structure
    ws_dir.mkdir(parents=True, exist_ok=True)
    (ws_dir / ".ai").mkdir(exist_ok=True)
    (ws_dir / docs.lstrip("./")).mkdir(parents=True, exist_ok=True)

    # Write workspace.yaml inside the workspace-repo
    ws_data = {
        "project": {
            "name": name,
            "type": ptype,
            "architecture": architecture,
        },
        "workspace": {
            "repo": repo_name,
        },
        "paths": {
            "docs":   docs,
            "output": ".",
        },
        "agent_team": {
            "model":            model or "qwen2.5-coder:7b",
            "framework":        framework or None,
            "max_rework_task":  3,
            "max_rework_iter":  2,
        },
        "rag": {
            "enabled":     False,
            "embed_model": "nomic-embed-text",
            "llm_model":   model or "qwen2.5-coder:7b",
            "top_k":       5,
            "store_path":  ".rag",
        },
        "enforcement": {
            "forbidden_in_human_paths": [
                "**/*.java", "**/pom.xml", "**/Dockerfile",
                "**/docker-compose.yml", "**/.github/workflows/*.yml", "**/Makefile",
            ],
            "human_paths":  ["docs/"],
            "agent_paths":  ["src/", "openspec/"],
        },
    }

    (ws_dir / "workspace.yaml").write_text(yaml.dump(ws_data, default_flow_style=False))
    print(f"\n  ✓ Workspace created: {ws_dir}")
    print(f"  ✓ workspace.yaml   → {ws_dir / 'workspace.yaml'}")
    print(f"  ✓ docs/            → {ws_dir / docs.lstrip('./')}")
    print(f"  ✓ .ai/             → {ws_dir / '.ai'}")

    # Create symlink to agentcraft inside workspace for easy access
    symlink = ws_dir / "agentcraft"
    if not symlink.exists():
        try:
            symlink.symlink_to(AGENTCRAFT_HOME / "agentcraft")
            print(f"  ✓ agentcraft link  → {AGENTCRAFT_HOME / 'agentcraft'}")
        except OSError as e:
            print(f"  ⚠ Could not create agentcraft symlink: {e}")
            print(f"    Use the global agentcraft command instead.")

    print(f"""
  Workspace ready. Next steps:
    cd {repo_name}
    agentcraft diagnose       detect hardware, select models
    agentcraft build          validate and pull models
    agentcraft bootstrap      run the agent team
    agentcraft comms          start the chat UI

  Or install dependencies:
    agentcraft init --deps    install Python packages + aider
""")

    # Handle --deps flag
    if args.deps:
        print("\n  Installing Python dependencies...")
        import subprocess
        try:
            result = subprocess.run(
                [sys.executable, "-m", "pip", "install", "-q", "-r", AGENTCRAFT_HOME / "requirements.txt"],
                cwd=str(ws_dir),
                capture_output=True,
                text=True
            )
            if result.returncode == 0:
                print("  ✓ Python dependencies installed")

                import shutil
                if shutil.which("aider"):
                    print("  ✓ aider available")
                else:
                    print("  Installing aider...")
                    result = subprocess.run(
                        [sys.executable, "-m", "pip", "install", "-q", "aider-chat"],
                        cwd=str(ws_dir),
                        capture_output=True,
                        text=True
                    )
                    if result.returncode == 0:
                        print("  ✓ aider installed")
                    else:
                        print(f"  ⚠ aider installation issue: {result.stderr}")
            else:
                print(f"  ⚠ Dependency installation had issues: {result.stderr}")
        except Exception as e:
            print(f"  ⚠ Error during dependency installation: {e}")



